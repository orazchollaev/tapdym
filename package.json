    "@capacitor/core": "^8.4.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@lucide/vue": "^1.24.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
